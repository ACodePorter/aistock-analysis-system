  "strict_anti_scraping_domains": {
    "_description": "反爬虫严格的域名（需要特殊处理）",
    "sources": [
      {
        "domain": "weforum.org",
        "strategy": "special_headers",
        "rate_limit_seconds": [2.0, 5.0],
        "notes": "需要Google referer和英文语言头"
      },
      {
        "domain": "zhihu.com",
        "strategy": "cookie_rotation",
        "rate_limit_seconds": [2.0, 5.0],
        "notes": "需要清除cookies重试"
      },
      {
        "domain": "tianyancha.com",
        "strategy": "slow_rate",
        "rate_limit_seconds": [2.0, 5.0],
        "notes": "需要较慢的访问频率"
      },
      {
        "domain": "qcc.com",
        "strategy": "slow_rate",
        "rate_limit_seconds": [2.0, 5.0],
        "notes": "需要较慢的访问频率"
      }
    ]
  },
  
  "detection_rules": {
    "_description": "自动检测规则配置",
    "login_detection": {
      "enabled": true,
      "keywords": [
        "登录",
        "login",
        "weblogin",
        "会员帐户安全",
        "需与您确认",
        "确认此网页操作",
        "请先登录",
        "验证码",
        "captcha"
      ],
      "http_status_codes": [302, 401, 403],
      "redirect_patterns": [
        "/login",
        "/weblogin",
        "/signin",
        "/auth"
      ]
    },
    "content_quality": {
      "min_content_length": 100,
      "max_content_length": 100000,
      "blocked_phrases": [
        "为提升会员帐户安全",
        "请先登录",
        "验证码错误",
        "页面不存在",
        "404",
        "403 Forbidden"
      ]
    }
  }
