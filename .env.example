
# Timezone & schedule
TZ=Asia/Taipei
CRON_HOUR=16
CRON_MINUTE=10
MACRO_CRON_HOUR=19
MACRO_CRON_MINUTE=45
MACRO_TRAIN_CRON_HOUR=20
MACRO_TRAIN_CRON_MINUTE=15
MACRO_CRON_HOUR=19
MACRO_CRON_MINUTE=45
MACRO_TRAIN_CRON_HOUR=20
MACRO_TRAIN_CRON_MINUTE=15

# Logging
LOG_FILE=logs/backend/app.log
LOG_LEVEL=INFO
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# DB
# Default for deployed stack: service `db` listens on its internal 5432.
# For local development with `docker-compose.local.yml`, the container 5432
# is published to the host at 5433 ("5433:5432"), so set POSTGRES_PORT=5433
# when connecting to the container from the host.
POSTGRES_DB=aistock
POSTGRES_USER=aiuser
POSTGRES_PASSWORD=ai_pass_123
POSTGRES_HOST=db
POSTGRES_PORT=5433

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# SearXNG Configuration
SEARXNG_URL=http://searxng:8081
SEARXNG_TIMEOUT=30

# MongoDB Configuration
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=password123
MONGO_DB=aistock_news

# Backend
FORECAST_AHEAD_DAYS=5
DATA_SOURCE=akshare        # akshare | tushare
TUSHARE_TOKEN=

# Azure OpenAI 配置（留空则禁用 LLM 摘要）
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_TIMEOUT=30

# Macro observation & training
MACRO_NEWS_TIME_RANGE=day
MACRO_MAX_ARTICLES=20
MACRO_ANALYSIS_BATCH=5
MACRO_CRAWL_CONCURRENCY=4
MACRO_MIN_RELEVANCE=0.2
MACRO_MAX_KEYWORDS=10
MACRO_MAX_REFERENCES=8
MACRO_TARGET_SYMBOL=000300.SH
MACRO_FORECAST_HORIZON=1
MACRO_LOOKBACK_DAYS=180
MACRO_MODEL_NAME=macro_linear_regression
MACRO_USE_RIDGE=false
MACRO_RIDGE_ALPHA=0.8
MACRO_SENTIMENT_FLOOR=-1
MACRO_SENTIMENT_CAP=1
